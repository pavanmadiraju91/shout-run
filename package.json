{
  "name": "shout",
  "version": "0.1.0",
  "private": true,
  "description": "Terminal broadcasting for AI agents and developers",
  "homepage": "https://shout.run",
  "author": "pavanmadiraju91",
  "keywords": [
    "terminal",
    "broadcasting",
    "live",
    "developer-tools",
    "cli",
    "pty",
    "websocket",
    "xterm"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/pavanmadiraju91/shout-run.git"
  },
  "license": "MIT",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean",
    "test": "turbo test",
    "test:ci": "turbo test -- --coverage"
  },
  "pnpm": {
    "overrides": {
      "flatted": ">=3.4.2"
    }
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "turbo": "^2.9.3",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
