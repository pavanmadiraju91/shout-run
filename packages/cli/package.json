{
  "name": "@shout/cli",
  "version": "0.1.0",
  "description": "CLI for shout - live terminal broadcasting",
  "type": "module",
  "bin": {
    "shout": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "name": "shout-cli",
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@shout/shared": "workspace:*",
    "chalk": "^5.3.0",
    "commander": "^14.0.3",
    "open": "^11.0.0",
    "ora": "^9.3.0",
    "ws": "^8.18.0"
  },
  "optionalDependencies": {
    "keytar": "^7.9.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/ws": "^8.5.12",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20"
  }
}
