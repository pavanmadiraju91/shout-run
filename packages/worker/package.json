{
  "name": "@shout/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "prebuild": "node scripts/copy-vt-wasm.js",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "pretest": "node scripts/ensure-vt-wasm.js",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo .wrangler"
  },
  "dependencies": {
    "@libsql/client": "^0.17.3",
    "@shout/shared": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.16"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260501.1",
    "@shout/vt-wasm": "workspace:*",
    "typescript": "^6.0.3",
    "wrangler": "^4.87.0"
  }
}
