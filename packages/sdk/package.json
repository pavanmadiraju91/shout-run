{
  "name": "@shout/sdk",
  "version": "0.3.0",
  "description": "TypeScript SDK for shout.run - broadcast your terminal from code",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@shout/shared": "workspace:*",
    "@types/node": "^25.6.0",
    "@types/ws": "^8.5.12",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "name": "shout-run-sdk",
    "access": "public"
  },
  "license": "MIT",
  "author": "Pavan Madiraju",
  "repository": {
    "type": "git",
    "url": "https://github.com/pavanmadiraju91/shout-run.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://shout.run",
  "keywords": [
    "terminal",
    "broadcast",
    "live",
    "sdk",
    "agent",
    "ai",
    "streaming",
    "developer-tools"
  ]
}
